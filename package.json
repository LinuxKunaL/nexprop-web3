{
  "name": "nexprop",
  "version": "1.0.0",
  "description": "Nexprop Application",
  "scripts": {
    "start:app": "cd client && npm run start",
    "start:app:mirror": "scrcpy",
    "start:app:android": "cd client && npm run android",
    "install:client:packages": "cd client && npm install",
    "install:server:packages": "cd server && npm install",
    "build:android:debug-apk": "cd client/android && ./gradlew assembleDebug",
    "build:android:release-apk": "cd client/android && ./gradlew assembleRelease",
    "install:debug:apk": "adb install client/android/app/build/outputs/apk/debug/app-debug.apk",
    "install:release:apk": "adb install client/android/app/build/outputs/apk/release/app-release.apk"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
